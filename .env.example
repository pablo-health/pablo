# AI/LLM Configuration for Local Development
# Model to use for SOAP note generation (aisuite format: provider:model)
# Examples: google:gemini-3-pro-preview, anthropic:claude-3-sonnet, openai:gpt-4
AI_MODEL=google:gemini-3-pro-preview

# Google Cloud Project (required for Vertex AI)
# Replace with your GCP project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Cloud Region (gemini-3-pro-preview requires "global")
GOOGLE_REGION=global
