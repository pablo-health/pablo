# AI/LLM Configuration for Local Development
# Model to use for SOAP note generation (aisuite format: provider:model)
# Examples: google:gemini-3.1-pro-preview, anthropic:claude-3-sonnet, openai:gpt-4
AI_MODEL=google:gemini-3.1-pro-preview

# Google Cloud Project (required for Vertex AI)
# Replace with your GCP project ID
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Google Cloud Region (gemini-3.1-pro-preview requires "global")
GOOGLE_REGION=global


# Calendar Feed Encryption (AES-256-GCM)
# Encrypts iCal feed URLs at rest (bearer-token-equivalent secrets)
# Generate with: python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
GOOGLE_CALENDAR_ENCRYPTION_KEY=

# Practice Mode (optional, requires PRACTICE_ENABLED=true)
PRACTICE_ENABLED=false
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=OhisAd2u8Q6qSA4xXAAT
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# ASR (Speech-to-Text) for Practice Mode
# Supported: assemblyai, google
ASR_PROVIDER=assemblyai
ASSEMBLYAI_API_KEY=your-assemblyai-api-key
