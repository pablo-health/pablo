# ============================================================================
# Pablo - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in the appropriate values for your environment.
# DO NOT commit .env to version control - it contains sensitive secrets.

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
DEBUG=false
LOG_LEVEL=INFO
# Environment defaults to production for security (fail-safe default)
# Must explicitly set ENVIRONMENT=development for local development
ENVIRONMENT=development  # development, staging, or production

# ----------------------------------------------------------------------------
# Security Settings - HIPAA TLS Requirements
# ----------------------------------------------------------------------------
# HTTPS is automatically enforced based on ENVIRONMENT:
#   - development: HTTP allowed (for localhost testing)
#   - staging/production: HTTPS strictly enforced
# HSTS (HTTP Strict Transport Security) settings for production
HSTS_MAX_AGE=63072000  # 2 years in seconds (production only — matches privacy policy + browser-vendor preload recommendation)
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# ----------------------------------------------------------------------------
# BAA (Business Associate Agreement) Settings
# ----------------------------------------------------------------------------
# Require BAA acceptance before PHI access
# Set to true for SaaS deployments (default)
# Set to false for self-hosted installations where therapist hosts for themselves
# Self-hosted therapists don't need a BAA with themselves
REQUIRE_BAA=true

# ----------------------------------------------------------------------------
# MFA (Multi-Factor Authentication) Settings
# ----------------------------------------------------------------------------
# Require TOTP MFA for all users (HIPAA §164.312(d) strong authentication)
# Set to false only for local development
REQUIRE_MFA=true

# ----------------------------------------------------------------------------
# Sign-up Restriction Settings
# ----------------------------------------------------------------------------
# Only allowlisted emails can sign in (defense-in-depth behind blocking functions)
# Set to false to allow any authenticated user
RESTRICT_SIGNUPS=true

# ----------------------------------------------------------------------------
# API Settings
# ----------------------------------------------------------------------------
API_TITLE=Pablo API
API_DESCRIPTION=Backend API for therapy session management and SOAP note generation

# ----------------------------------------------------------------------------
# CORS Settings
# ----------------------------------------------------------------------------
# Comma-separated list of allowed origins
# For development: http://localhost:3000,http://localhost:5173
# For production: https://yourdomain.com
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true

# ----------------------------------------------------------------------------
# Database Settings (PostgreSQL)
# ----------------------------------------------------------------------------
DATABASE_URL=postgresql://pablo:pablo_dev@localhost:5432/pablo

# ----------------------------------------------------------------------------
# Google Cloud Platform Settings
# ----------------------------------------------------------------------------
GCP_PROJECT_ID=your-gcp-project-id

# Note: Cloud Audit Logs are configured at the GCP project level,
# not via environment variables. See docs/HIPAA_AUDIT_LOGS.md for setup instructions.
# Run: backend/scripts/enable-audit-logs.sh

# ----------------------------------------------------------------------------
# Firebase Authentication
# ----------------------------------------------------------------------------
# Firebase project ID (defaults to GCP_PROJECT_ID if not set)
FIREBASE_PROJECT_ID=
# Uncomment for local development with Firebase Auth Emulator
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099

# ----------------------------------------------------------------------------
# Redis Settings
# ----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SSL=false

# Cache TTL in seconds (default: 5 minutes)
CACHE_TTL_SECONDS=300

# ----------------------------------------------------------------------------
# Eval Export Queue Settings
# ----------------------------------------------------------------------------
# Control which finalized sessions are queued for eval export
# Low-rated sessions (rating ≤ LOW_RATING_THRESHOLD) are always queued
# High-rated sessions (rating ≥ HIGH_RATING_THRESHOLD) are sampled at HIGH_RATING_SAMPLE_RATE
LOW_RATING_THRESHOLD=2
HIGH_RATING_THRESHOLD=4
HIGH_RATING_SAMPLE_RATE=0.10  # 10% of high-rated sessions

# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# Server-Side Transcription
# ----------------------------------------------------------------------------
# Enable server-side transcription for audio uploads
TRANSCRIPTION_ENABLED=false
# Provider: "whisper" (self-hosted GCP Batch + spot GPU) or "assemblyai" (API)
# Whisper: ~$0.02/session, requires GPU infra. AssemblyAI: ~$0.10/session (nano), zero infra.
TRANSCRIPTION_PROVIDER=whisper
# GCS bucket for encrypted audio storage (Whisper provider only)
TRANSCRIPTION_AUDIO_BUCKET=pablo-audio
# Container image for Whisper worker (Whisper provider only)
TRANSCRIPTION_WORKER_IMAGE=gcr.io/your-project/pablo-transcription:latest
# Backend URL the worker/API calls back to with the transcript
TRANSCRIPTION_BACKEND_CALLBACK_URL=https://your-backend-url.run.app
# GCP region for Batch jobs (Whisper provider only)
TRANSCRIPTION_QUEUE_LOCATION=us-central1

# ----------------------------------------------------------------------------
# Calendar Feed Encryption (AES-256-GCM)
# ----------------------------------------------------------------------------
# Encrypts iCal feed URLs at rest (bearer-token-equivalent secrets)
# Generate with: python3 -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
GOOGLE_CALENDAR_ENCRYPTION_KEY=

# ----------------------------------------------------------------------------
# Google Cloud Secret Manager (Production Only)
# ----------------------------------------------------------------------------
# Set to true to load secrets from GCP Secret Manager instead of env vars
USE_SECRET_MANAGER=false

# ----------------------------------------------------------------------------
# AI/LLM Configuration (SOAP Note Generation)
# ----------------------------------------------------------------------------
# Model to use for SOAP note generation
# Options:
#   - google:gemini-pro (Vertex AI - requires GOOGLE_CLOUD_PROJECT)
#   - google:gemini-3.1-pro-preview (Gemini API - requires GOOGLE_API_KEY)
#   - anthropic:claude-sonnet-4-5 (Anthropic - requires ANTHROPIC_API_KEY)
#   - openai:gpt-4 (OpenAI - requires OPENAI_API_KEY)
AI_MODEL=google:gemini-pro

# Vertex AI Configuration (Option 1: uses gcloud credentials)
# Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_REGION=us-central1

# Gemini API Configuration (Option 2: requires API key)
# Get key from: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=your-api-key-here

# Anthropic API Configuration (Option 3)
# ANTHROPIC_API_KEY=your-api-key-here

# OpenAI API Configuration (Option 4)
# OPENAI_API_KEY=your-api-key-here

