rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Deny all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Patients: user_id-scoped CRUD
    // Each patient document has a user_id field for multi-tenant isolation
    match /patients/{patientId} {
      allow read: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
    }

    // Therapy sessions: user_id-scoped CRUD
    // Each session document has a user_id field for multi-tenant isolation
    match /therapy_sessions/{sessionId} {
      allow read: if request.auth != null
        && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null
        && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.user_id == request.auth.uid;
    }

    // Users: each user can only read/write their own document
    // Document ID is the Firebase Auth UID
    match /users/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    // Allowed emails: read-only for authenticated users
    // Admins manage entries via the backend API
    match /allowed_emails/{emailId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Audit logs: backend-only writes via Admin SDK (bypasses rules)
    // No client access permitted
    match /audit_logs/{logId} {
      allow read, write: if false;
    }
  }
}
