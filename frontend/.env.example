# Development Mode Configuration
# Set to "true" to enable auto-authentication bypass (local dev only)
DEV_MODE=true

# Set to "mock" to use mock data, "api" to use real backend API
DATA_MODE=mock

# Local Development Authentication
# Enable local username/password authentication (dev mode only)
# WARNING: Only works when DEV_MODE=true
ENABLE_LOCAL_AUTH=false

# Backend API URL (used when DATA_MODE=api)
API_URL=http://localhost:8000

# Firebase Client Config (NEXT_PUBLIC_ = embedded in client bundle)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Server Config (for next-firebase-auth-edge token verification)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Cookie signing key (generate with: openssl rand -base64 32)
AUTH_COOKIE_SIGNATURE_KEY=

# Quality Rating Feedback Threshold
# Require written feedback when rating is below this value (1-5)
RATING_FEEDBACK_REQUIRED_BELOW=5
